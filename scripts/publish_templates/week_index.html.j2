<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>Fantasy Ballers - {{ season }} - Week {{ week }}</title>
  <link rel="stylesheet" href="/assets/site.css" />
  <script src="/assets/site.js" defer></script>
</head>
<body>
  <div class="page">
    <div class="app">
      <header class="app-header">
        <div class="brand">
          <h1>Fantasy Football</h1>
          <span class="subtitle">Week {{ week }} · {{ season }} Season</span>
        </div>
        <div class="header-links">
          <a
            class="social-link"
            href="https://github.com/jon-appleby"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View my GitHub profile"
            title="GitHub"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.35 6.84
                   9.71.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21
                   -.45-1.17-1.11-1.48-1.11-1.48-.91-.64.07-.63.07-.63 1 .08 1.53 1.06
                   1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.64-1.37-2.22-.26-4.56-1.14-4.56-5.07
                   0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.3.1-2.72 0 0 .84-.28 2.75 1.05
                   A9.3 9.3 0 0 1 12 6.84a9.3 9.3 0 0 1 2.5.35c1.91-1.33 2.75-1.05 2.75-1.05
                   .55 1.42.2 2.46.1 2.72.64.72 1.03 1.64 1.03 2.76 0 3.94-2.34 4.81-4.57 5.07
                   .36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49
                   A10.24 10.24 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
              />
            </svg>
          </a>

          <a
            class="social-link"
            href="https://www.linkedin.com/in/jon-appleby"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View my LinkedIn profile"
            title="LinkedIn"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M6.5 8.25H3.25V20H6.5V8.25ZM4.88 3A1.88 1.88 0 1 0
                   4.88 6.75 1.88 1.88 0 0 0 4.88 3ZM20.75 13.26c0-3.54-1.89-5.19-4.42-5.19
                   -2.04 0-2.95 1.12-3.46 1.91V8.25H9.62V20h3.25v-5.82c0-1.53.29-3.01
                   2.19-3.01 1.87 0 1.89 1.75 1.89 3.11V20h3.25l.55-6.74Z"
              />
            </svg>
          </a>
        </div>
      </header>

      {% include "_sidebar.html.j2" %}

      <main class="app-main">
        <section class="content-card">
          <h2>Week {{ week }} - {{ season }} Season</h2>
          <p><a href="/ff/">&larr; Back to Fantasy Football</a></p>
        </section>

        <section class="content-card wide">
          <div class="chart-grid">
            {% for chart in charts %}
            <div class="chart-card">
              <h3>{{ chart.title }}</h3>
              <img src="/ff/{{ season }}/week-{{ week_padded }}/charts/{{ chart.filename }}"
                   alt="{{ chart.title }}" loading="lazy" />
              <p class="chart-desc">{{ chart.description }}</p>
            </div>
            {% endfor %}
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>